    "windows": {
      "architecture": "x86_64",
      "preset": "Internal Windows x86_64",
      "exported_binary": "builds/export/windows/lantern_house_internal.exe",
      "native_executable": "lantern_house_internal.exe",
      "launcher_source": "packaging/portable/launch_windows.cmd",
      "launcher_name": "launch.cmd"
    },
    "linux": {
      "architecture": "x86_64",
      "preset": "Internal Linux x86_64",
      "exported_binary": "builds/export/linux/lantern_house_internal.x86_64",
      "native_executable": "lantern_house_internal.x86_64",
      "launcher_source": "packaging/portable/launch_linux.sh",
      "launcher_name": "launch.sh"
    }
  },
  "common_files": {
    "START_HERE.md": "packaging/portable/START_HERE.md",
    "FACILITATOR_GUIDE.md": "docs/playtests/v0.1.3-pilot-guide.md",
    "OBSERVATION_SHEET.md": "docs/playtests/v0.1.3-observation-sheet.md",
    "POST_SESSION_QUESTIONNAIRE.md": "docs/playtests/v0.1.3-post-session-questionnaire.md",
    "PRIVACY_AND_LIMITATIONS.md": "packaging/portable/PRIVACY_AND_LIMITATIONS.md",
    "PILOT_SESSION_SCHEMA.json": "packaging/pilot/pilot_session_schema.json",
    "PILOT_SESSION_RECORD.json": "docs/playtests/v0.1.3-pilot-session-blank.json",
    "FINDINGS_REGISTER_SCHEMA.json": "packaging/pilot/findings_register_schema.json",
    "FINDINGS_REGISTER.json": "docs/playtests/v0.1.3-findings-register-blank.json",
    "THIRD_PARTY_NOTICES.md": "packaging/portable/THIRD_PARTY_NOTICES.md",
    "LICENSES/GODOT_ENGINE_LICENSE.txt": "packaging/portable/GODOT_ENGINE_LICENSE.txt"
