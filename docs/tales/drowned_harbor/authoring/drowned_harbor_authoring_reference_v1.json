    ],
    "audio_manifests": [
      "docs/tales/drowned_harbor/audio/drowned_harbor_audio_ambience_briefs_v1.json",
      "docs/tales/drowned_harbor/audio/drowned_harbor_audio_continuity_briefs_v1.json",
      "docs/tales/drowned_harbor/audio/drowned_harbor_audio_event_briefs_v1.json"
    ],
    "music_manifests": [
      "docs/tales/drowned_harbor/music/drowned_harbor_music_resolution_briefs_v1.json",
