      "blocks_production": true,
      "status": "open",
      "source_path": "docs/tales/drowned_harbor/Drowned_Harbor_Design_Bible.md"
    },
    {
      "id": "missing_assistant_identity",
      "summary": "Resolve the missing Bellhouse assistant identity, motive, and ultimate fate.",
      "blocks_production": true,
      "status": "open",
      "source_path": "docs/tales/drowned_harbor/Drowned_Harbor_Design_Bible.md"
    },
    {
      "id": "relief_vessel_identity",
      "summary": "Select the relief vessel name and final public-history treatment.",
      "blocks_production": false,
      "status": "deferred",
      "source_path": "docs/tales/drowned_harbor/Drowned_Harbor_Design_Bible.md"
    },
    {
      "id": "tidebound_conversion_rules",
      "summary": "Define exact deterministic Tidebound eligibility, refusal, conversion, spread, cure, and ending behavior.",
      "blocks_production": true,
      "status": "open",
      "source_path": "docs/tales/drowned_harbor/Drowned_Harbor_Design_Bible.md"
    },
    {
      "id": "underteller_prior_hosting",
      "summary": "Decide whether the provisional host has presented an earlier version of the Tale.",
      "blocks_production": false,
      "status": "deferred",
      "source_path": "docs/tales/drowned_harbor/Drowned_Harbor_Design_Bible.md"
    }
  ],
  "compilation_boundary": {
