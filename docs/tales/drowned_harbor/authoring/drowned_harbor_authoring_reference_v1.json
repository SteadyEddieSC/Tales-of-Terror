    "accessibility_manifests": [
      "docs/tales/drowned_harbor/accessibility/drowned_harbor_accessible_narrative_stage_units_v1.json",
      "docs/tales/drowned_harbor/accessibility/drowned_harbor_accessible_reveal_continuity_units_v1.json"
    ],
    "traceability_path": "docs/preproduction/drowned_harbor_cross_media_traceability_v1.json"
  },
  "fallbacks": {
    "cooperative_mode": "cooperative",
    "no_phone": "shared_screen_controller_complete",
    "optional_companion_unavailable": "continue_native_authority",
    "voice_unavailable": "plain_system_text_and_captions",
    "music_unavailable": "continue_without_music",
    "noncritical_media_unavailable": "use_original_placeholder_or_text",
    "invalid_action": "reject_without_mutation_show_legal_options",
    "defeat_continuation": "offer_authored_form_replacement_or_terminal_result",
    "unsupported_optional_feature": "fail_closed_before_session"
  },
  "validation_obligations": [
    {
      "id": "all_final_routes_attribute_outcomes",
      "requirement": "Every reachable ending must assign an explicit public or controlled-private outcome to every stable seat and faction.",
      "status": "declared_preproduction"
    },
    {
      "id": "connector_state_per_tide",
      "requirement": "Every connector must have an authored state for every supported tide state before runtime implementation.",
      "status": "declared_preproduction"
    },
    {
      "id": "human_accessibility_validation",
      "requirement": "Television readability, caption pacing, controller focus, and assistive-technology behavior require human validation.",
      "status": "human_validation_required"
    },
    {
      "id": "human_audio_visual_validation",
      "requirement": "Visual clarity, sound quality, music fatigue, and voice intelligibility require human review on representative hardware.",
      "status": "human_validation_required"
    },
    {
      "id": "human_gameplay_validation",
      "requirement": "Fun, pacing, balance, fairness, social tension, and comprehension require exact-build human playtesting.",
      "status": "human_validation_required"
    },
    {
      "id": "rejected_mutation_is_noop",
      "requirement": "Every invalid, stale, duplicate, wrong-seat, or unavailable action must leave authoritative state and RNG unchanged.",
      "status": "declared_preproduction"
    },
    {
      "id": "stable_seat_continuity",
      "requirement": "Disconnect, surrogate activation, takeover, return, defeat, transformation, and continuation must preserve stable-seat-owned state.",
      "status": "declared_preproduction"
    },
    {
      "id": "terminal_reachability",
      "requirement": "Every supported route must retain a reachable valid ending or authored continuation after each committed transformation.",
      "status": "declared_preproduction"
    }
  ],
  "open_decisions": [
    {
      "id": "bellmarked_origin",
      "summary": "Resolve the exact origin and historical formation of the Bellmarked faction.",
      "blocks_production": true,
      "status": "open",
      "source_path": "docs/tales/drowned_harbor/Drowned_Harbor_Design_Bible.md"
    },
    {
