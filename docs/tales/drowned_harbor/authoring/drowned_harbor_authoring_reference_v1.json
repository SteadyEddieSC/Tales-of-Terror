{
  "authoring_kind": "tale_authoring_reference",
  "schema_version": 1,
  "tale_id": "drowned_harbor",
  "reference_version": 1,
  "display_name": "Drowned Harbor",
  "production_status": "design_only",
  "runtime_integration_authorized": false,
  "production_catalog_authorized": false,
  "source_authorities": [
    "docs/design/Seat_Continuity_and_Admission.md",
    "docs/preproduction/drowned_harbor_cross_media_traceability_v1.json",
    "docs/tales/drowned_harbor/Drowned_Harbor_Design_Bible.md",
    "docs/technical/Tale_Authoring_Reference_Contract_v1.md"
  ],
  "compatibility": {
    "engine_target": "godot_4_7",
    "minimum_seats": 1,
    "maximum_seats": 8,
    "modes": [
      {
        "id": "cooperative",
        "status": "supported",
        "minimum_seats": 1,
        "maximum_seats": 8,
        "privacy_model": "public_only",
        "fallback_mode": null
      },
      {
        "id": "hidden_betrayer",
        "status": "supported",
        "minimum_seats": 3,
        "maximum_seats": 8,
        "privacy_model": "optional_hidden_faction",
        "fallback_mode": "cooperative"
      },
      {
        "id": "hunted",
        "status": "deferred",
        "minimum_seats": 2,
        "maximum_seats": 8,
        "privacy_model": "optional_hidden_faction",
        "fallback_mode": "cooperative"
      },
      {
        "id": "outbreak",
        "status": "supported",
        "minimum_seats": 2,
        "maximum_seats": 8,
        "privacy_model": "dynamic_faction",
        "fallback_mode": "cooperative"
      },
      {
        "id": "rival_crews",
        "status": "deferred",
        "minimum_seats": 4,
        "maximum_seats": 8,
        "privacy_model": "mixed_public_competition",
        "fallback_mode": "cooperative"
      }
    ]
  },
  "privacy_classes": [
    "controlled_reveal_private",
    "faction_private",
    "public",
    "seat_private"
  ],
  "stage_graph": {
    "entry_stage": "low_tide_arrival",
    "required_terminal_stage": "last_light",
    "stage_order": [
      "low_tide_arrival",
      "bellhouse_ledger",
      "lighthouse_council",
      "high_water",
      "last_light"
    ],
    "transitions": [
      {
        "id": "advance_bellhouse_to_council",
        "from": "bellhouse_ledger",
        "to": "lighthouse_council",
        "trigger_id": "bellhouse_priority_committed",
        "once_only": true
      },
      {
        "id": "advance_high_water_to_last_light",
        "from": "high_water",
        "to": "last_light",
        "trigger_id": "high_water_objectives_resolved",
        "once_only": true
      },
      {
        "id": "commit_council_high_water",
        "from": "lighthouse_council",
        "to": "high_water",
        "trigger_id": "lighthouse_council_committed",
        "once_only": true
      },
      {
        "id": "advance_low_tide_to_bellhouse",
        "from": "low_tide_arrival",
        "to": "bellhouse_ledger",
        "trigger_id": "low_tide_record_threshold_reached",
        "once_only": true
      }
    ]
  },
  "signature_transformations": [
    {
      "id": "high_water_transform",
      "source_stage": "lighthouse_council",
      "target_stage": "high_water",
      "trigger_id": "lighthouse_council_committed",
      "deterministic": true,
      "once_only": true,
      "minimum_changed_state_categories": 2,
      "allowed_state_categories": [
        "board",
        "encounter_eligibility",
        "ending_eligibility",
        "faction",
        "form",
        "objective",
        "resource_economy",
        "route"
      ]
    }
  ],
  "content_manifests": [
    "docs/tales/drowned_harbor/authoring/drowned_harbor_gameplay_content_v1.json",
    "docs/tales/drowned_harbor/authoring/drowned_harbor_narrative_content_v1.json",
    "docs/tales/drowned_harbor/authoring/drowned_harbor_social_content_v1.json",
    "docs/tales/drowned_harbor/authoring/drowned_harbor_world_content_v1.json"
  ],
  "media_sources": {
