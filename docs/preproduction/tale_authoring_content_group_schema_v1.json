{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://steadyeddiesc.example/schemas/tale-authoring-content-groups-v1.json",
  "title": "Tale Authoring Content Groups v1",
  "description": "Closed preproduction content-group manifest referenced by a Tale authoring reference.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_kind",
    "schema_version",
    "tale_id",
    "manifest_id",
    "production_status",
    "groups"
  ],
  "$defs": {
    "stable_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "repo_path": {
      "type": "string",
      "pattern": "^(docs|game|tools)/[A-Za-z0-9_./-]+$"
    },
    "content_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "status",
        "privacy",
        "stages",
        "tags",
        "source_path",
        "source_anchor",
        "traceability_concepts",
        "ids",
        "note"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "stage",
            "tide_state",
            "space",
            "region",
            "mode",
            "role",
            "faction",
            "form",
            "resource",
            "item",
            "card",
            "hazard",
            "encounter",
            "ending"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "preproduction_ready",
            "review_required",
            "deferred"
          ]
        },
        "privacy": {
          "type": "string",
          "enum": [
            "public",
            "controlled_reveal_private",
            "seat_private",
            "faction_private"
          ]
        },
        "stages": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/stable_id"
          }
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "active_continuation",
              "authored_recovery_required",
              "controlled_reveal_required",
              "deterministic_consequence",
              "explicit_outcome_attribution",
              "generic_alternative_required",
              "legal_choices_required",
              "mechanical_truth_required",
              "optional_hidden_state",
              "public_warning_required",
              "stable_seat_continuation",
              "stateful_condition",
              "transformation_preserves_agency",
              "warning_response_recovery"
            ]
          }
        },
        "source_path": {
          "$ref": "#/$defs/repo_path"
        },
        "source_anchor": {
          "type": "string",
          "minLength": 3
        },
        "traceability_concepts": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^DH-XM-[0-9]{3}$"
          }
        },
        "ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/stable_id"
          }
        },
        "note": {
          "type": "string",
          "minLength": 10
        }
      }
    }
  },
  "properties": {
    "manifest_kind": {
      "type": "string",
      "const": "tale_authoring_content_groups"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "tale_id": {
      "$ref": "#/$defs/stable_id"
    },
    "manifest_id": {
      "$ref": "#/$defs/stable_id"
    },
    "production_status": {
      "type": "string",
      "const": "design_only"
    },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/content_group"
      }
    }
  }
}
